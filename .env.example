# Copy to .env and fill in values.
# Kompyla reads these at startup; values here override config.yaml.

# ── LLM providers ──────────────────────────────────────────────────────────
# Uncomment ONE key; the provider is auto-detected from whichever key is set.
# Override auto-detection explicitly with KOMPYLA_LLM_PROVIDER if needed.
#
# KOMPYLA_LLM_PROVIDER=anthropic   # ollama | anthropic | openai | gemini | groq
# KOMPYLA_LLM_MODEL=claude-opus-4-7  # overrides the default model for the chosen provider
#
# OLLAMA_BASE_URL=http://localhost:11434   # default; change when using bundled Ollama
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# GROQ_API_KEY=gsk_...              # free tier: console.groq.com — recommended for testing

# ── Web search ──────────────────────────────────────────────────────────────
# Priority: first key present wins. If none are set, DuckDuckGo is used as a
# free fallback (no key required).
#
# SERPER_API_KEY=...         # Google results via serper.dev  ($1/1K queries)
# BRAVE_API_KEY=...          # Brave Search API  (free tier: 2K queries/month)
# EXA_API_KEY=...            # Exa.ai semantic search  (free tier available)
# SERPAPI_API_KEY=...        # SerpAPI multi-engine  (requires kompyla[search])

# ── Other retrieval ─────────────────────────────────────────────────────────
# GITHUB_TOKEN=ghp_...       # optional — raises GitHub API rate limit
