# Copy to .env and fill in values.
# Kompyla reads these at startup to override config.yaml values.

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...        # only if provider=anthropic
# OLLAMA_BASE_URL=http://localhost:11434

# --- Retrieval (Phase 2) ---
TAVILY_API_KEY=tvly-...              # web search (https://tavily.com)
GITHUB_TOKEN=ghp_...                 # optional, raises GitHub API rate limit
